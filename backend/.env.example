# Copy to .env and fill in. Never commit .env.

# Postgres connection string from Supabase → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# Symmetric key used to encrypt Spotify refresh tokens at rest.
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Secret used to sign session JWTs issued to the iOS app.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Spotify app credentials — same Client ID the iOS app uses.
SPOTIFY_CLIENT_ID=beb87efbee1d4fe89a69ab1b85b68a23

# Optional: lifetime of session JWTs in days (default 30)
JWT_LIFETIME_DAYS=30

# Run mode (dev | prod). prod enables stricter CORS, hides docs.
APP_ENV=dev

# ---------- Poll worker -----------------------------------------------------
# Set to false to disable the background poller (useful when running multiple
# API instances; only one should poll).
WORKER_ENABLED=true
# Seconds between polls per user. Spotify rate limits aren't published but
# ~1 req/sec/user is safe. 8 is a good balance of freshness vs API budget.
WORKER_POLL_INTERVAL=8

# ---------- APNs silent push (requires PAID Apple Developer account) -------
# Leave APNS_KEY_ID empty to disable push entirely (worker still detects
# changes — handy in dev on a free account).
APNS_KEY_ID=
APNS_TEAM_ID=
# Bundle ID of the iOS app target (NOT the widget extension).
APNS_TOPIC=kkaay.duo-sync
# Path to your .p8 auth key file. On Railway, paste the key contents into
# APNS_PRIVATE_KEY instead and leave APNS_KEY_PATH unset.
APNS_KEY_PATH=
APNS_PRIVATE_KEY=
# true = production APNs gateway (TestFlight/App Store builds)
# false = sandbox gateway (Xcode debug builds)
APNS_USE_SANDBOX=true
