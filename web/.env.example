# duo-sync web — copy to .env.local and fill in.

# Backend (FastAPI) — same one the iOS app talks to.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Supabase project — used for Realtime now-playing subscription.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Spotify Client ID (same one the iOS app uses).
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=beb87efbee1d4fe89a69ab1b85b68a23

# Where Spotify should redirect back after OAuth. Must match exactly
# in your Spotify dashboard → app → Redirect URIs.
# Local dev: http://127.0.0.1:3000/auth/callback
# Production: https://YOUR_DOMAIN/auth/callback
NEXT_PUBLIC_SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/auth/callback

# VAPID PUBLIC key (server holds the private key). Browser uses this
# to subscribe to push.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
